<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Débit Yonne - Seine - Loing</title>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
body {
    font-family: Arial, sans-serif;
    background: #f4f7fb;
    margin: 0;
    padding: 20px;
    max-width: 1200px;
    margin: auto;
}

h1 {
    text-align: center;
}

.header {
    text-align: center;
    color: #555;
    margin-bottom: 20px;
}

.grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 15px;
}

.card {
    background: white;
    padding: 15px;
    border-radius: 10px;
    box-shadow: 0 2px 6px rgba(0,0,0,0.1);
}

.card h3 {
    margin: 0;
}

.value {
    font-size: 28px;
    font-weight: bold;
    margin-top: 10px;
}

.total {
    background: #e8f3ff;
}

.chart {
    background: white;
    margin-top: 25px;
    padding: 15px;
    border-radius: 10px;
}
</style>

</head>

<body>

<h1>Débit entrant vers Montereau</h1>

<div class="header" id="update">Chargement...</div>

<div class="grid">

<div class="card">
<h3>Yonne</h3>
<p>Pont-sur-Yonne</p>
<div class="value" id="yonne">--</div>
</div>

<div class="card">
<h3>Seine</h3>
<p>Bazoches-lès-Bray</p>
<div class="value" id="seine">--</div>
</div>

<div class="card">
<h3>Loing</h3>
<p>Épisy</p>
<div class="value" id="loing">--</div>
</div>

<div class="card total">
<h3>Total</h3>
<p>Somme des débits</p>
<div class="value" id="total">--</div>
</div>

</div>

<div class="chart">
<canvas id="chart"></canvas>
</div>

<script>

const STATIONS = {
    yonne: "F358000402",
    seine: "F240000106",
    loing: "F439000101"
};

let chart;

async function fetchLatest(code) {

    const url = `https://hubeau.eaufrance.fr/api/v2/hydrometrie/obs_elab?code_entite=${code}&size=1&grandeur_hydro=Q`;

    const res = await fetch(url);
    const json = await res.json();

    if (!json.data || json.data.length === 0) return null;

    const val_l_s = json.data[0].resultat_obs;

    return {
        m3s: val_l_s / 1000,
        date: json.data[0].date_obs
    };
}

async function refresh() {

    try {

        const [y, s, l] = await Promise.all([
            fetchLatest(STATIONS.yonne),
            fetchLatest(STATIONS.seine),
            fetchLatest(STATIONS.loing)
        ]);

        document.getElementById("yonne").innerText = y.m3s.toFixed(1) + " m³/s";
        document.getElementById("seine").innerText = s.m3s.toFixed(1) + " m³/s";
        document.getElementById("loing").innerText = l.m3s.toFixed(1) + " m³/s";

        const total = y.m3s + s.m3s + l.m3s;

        document.getElementById("total").innerText = total.toFixed(1) + " m³/s";

        document.getElementById("update").innerText =
            "Dernière mise à jour : " + new Date().toLocaleString("fr-FR");

        updateChart(y.m3s, s.m3s, l.m3s);

    } catch (e) {
        console.error(e);
        document.getElementById("update").innerText = "Erreur de chargement API";
    }
}

function updateChart(y, s, l) {

    const data = [y, s, l];

    if (!chart) {

        chart = new Chart(document.getElementById("chart"), {
            type: "bar",
            data: {
                labels: ["Yonne", "Seine", "Loing"],
                datasets: [{
                    label: "Débit (m³/s)",
                    data: data
                }]
            }
        });

    } else {
        chart.data.datasets[0].data = data;
        chart.update();
    }
}

refresh();
setInterval(refresh, 15 * 60 * 1000);

</script>

</body>
</html>
